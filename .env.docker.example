# ==========================================
# POSTGRES DATABASE CONFIGURATION
# ==========================================
POSTGRES_USER=myuser
POSTGRES_PASSWORD=YOUR_DB_PASSWORD_HERE
POSTGRES_DB=mydbname

# ==========================================
# BACKEND (.NET) CONFIGURATION
# ==========================================
# หมายเหตุ: Host ต้องชี้ไปที่ชื่อบริการใน docker-compose ซึ่งคือ postgres-db
ConnectionStrings__DefaultConnection=Host=postgres-db;Port=5432;Database=mydbname;Username=myuser;Password=YOUR_DB_PASSWORD_HERE;Trust Server Certificate=true;

AzureAd__Instance=https://login.microsoftonline.com/
AzureAd__TenantId=YOUR_AZURE_AD_TENANT_ID
AzureAd__ClientId=YOUR_AZURE_AD_CLIENT_ID
AzureAd__Audience=YOUR_AZURE_AD_AUDIENCE

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
AZURE_AD_CLIENT_ID=YOUR_AZURE_AD_CLIENT_ID
AZURE_AD_CLIENT_SECRET=YOUR_AZURE_AD_CLIENT_SECRET
AZURE_AD_TENANT_ID=YOUR_AZURE_AD_TENANT_ID
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_STRING
NEXTAUTH_URL=https://asset.tonkla.studio
NEXTAUTH_URL_INTERNAL=http://frontend:3000
API_BASE_URL=http://backend:8080/api

# ==========================================
# CADDY CONFIGURATION
# ==========================================
# Use asset.tonkla.studio for direct 80/443 mode.
# Use :80 when a Cloudflare Tunnel terminates TLS and forwards HTTP to Caddy.
SITE_ADDRESS=asset.tonkla.studio
